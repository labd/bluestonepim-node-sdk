{
  "name": "@labdigital/bluestonepim-sdk",
  "version": "0.0.3",
  "description": "Bluestone PIM SDK",
  "keywords": [
    "sdk",
    "bluestone",
    "bluestonepim",
    "pim"
  ],
  "license": "MIT",
  "author": "Lab Digital <opensource@labdigital.nl>",
  "repository": {
    "type": "git",
    "url": "https://github.com/labd/bluestonepim-node-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "pnpm lint",
    "format": "eslint src --fix && prettier --write .",
    "lint": "eslint src && prettier --check .",
    "sdk:generate": "openapi-generator-cli generate -i https://docs.api.bluestonepim.com/openapi/665580c80a124b001f16a96c -g typescript-fetch -o src/ --additional-properties=prefixParameterInterfaces=true && pnpm format",
    "publish:ci": "pnpm build && pnpm changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@openapitools/openapi-generator-cli": "2.15.3",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^8.57.0",
    "eslint-plugin-sort-class-members": "^1.20.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.4.12",
    "tsup": "^8.3.5",
    "vite-tsconfig-paths": "5.1.3",
    "vitest": "2.1.6"
  },
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ]
}
