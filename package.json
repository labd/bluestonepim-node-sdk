{
	"name": "@labdigital/bluestonepim-sdk",
	"version": "0.0.4",
	"description": "Bluestone PIM SDK",
	"keywords": [
		"sdk",
		"bluestone",
		"bluestonepim",
		"pim"
	],
	"license": "MIT",
	"author": "Lab Digital <opensource@labdigital.nl>",
	"repository": {
		"type": "git",
		"url": "https://github.com/labd/bluestonepim-node-sdk"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"check": "pnpm lint && pnpm format && pnpm typecheck",
		"format": "biome format",
		"format:fix": "biome format --write",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"lint:knip": "knip",
		"test": "vitest run",
		"typecheck": "tsgo --noEmit",
		"sdk:generate": "openapi-generator-cli generate -i https://docs.api.bluestonepim.com/openapi/665580c80a124b001f16a96c -g typescript-fetch -o src/ --additional-properties=prefixParameterInterfaces=true && pnpm format:fix",
		"publish:ci": "pnpm build && pnpm changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.27.10",
		"@openapitools/openapi-generator-cli": "2.15.3",
		"@types/node": "^24.12.4",
		"@typescript/native-preview": "7.0.0-dev.20260519.1",
		"@vitest/coverage-v8": "^2.1.6",
		"knip": "^5.66.0",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "5.1.3",
		"vitest": "2.1.6"
	},
	"packageManager": "pnpm@11.4.0",
	"engines": {
		"node": ">=24",
		"pnpm": "11"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"src"
	]
}
